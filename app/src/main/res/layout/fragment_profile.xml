<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/gris_fondo"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_horizontal"
        android:orientation="vertical"
        android:padding="32dp">

        <com.google.android.material.card.MaterialCardView
            android:layout_width="150dp"
            android:layout_height="150dp"
            android:layout_marginTop="24dp"
            app:cardCornerRadius="75dp"
            app:cardElevation="12dp"
            app:strokeColor="@color/white"
            app:strokeWidth="5dp">

            <ImageView
                android:id="@+id/ivProfilePicture"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="centerCrop"
                android:src="@android:drawable/ic_menu_report_image"
                android:background="@color/gris_suave" />
        </com.google.android.material.card.MaterialCardView>

        <TextView
            android:id="@+id/tvProfileName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:textStyle="bold"
            android:text="JOAQUÍN"
            android:textColor="@color/azul_noche"
            android:textSize="32sp"
            android:letterSpacing="-0.03" />

        <TextView
            android:id="@+id/tvProfileEmail"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="usuario@ejemplo.com"
            android:textColor="@color/gris_texto_secundario"
            android:textSize="16sp"
            android:alpha="0.8" />

        <View
            android:layout_width="60dp"
            android:layout_height="6dp"
            android:layout_marginTop="24dp"
            android:layout_marginBottom="40dp"
            android:background="@color/azul_noche"
            android:backgroundTint="@color/azul_noche" />

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="28dp"
            app:cardElevation="6dp"
            app:strokeColor="#101A1C2E"
            app:strokeWidth="1dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="24dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="28dp"
                    android:letterSpacing="0.15"
                    android:text="ESTADÍSTICAS DE COLECCIÓN"
                    android:textColor="@color/azul_noche"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:alpha="0.6" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="44dp"
                        android:layout_height="44dp"
                        app:cardCornerRadius="12dp"
                        app:cardBackgroundColor="@color/gris_suave"
                        app:cardElevation="0dp">
                        <ImageView
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:layout_gravity="center"
                            android:src="@android:drawable/ic_menu_view"
                            app:tint="@color/azul_noche" />
                    </com.google.android.material.card.MaterialCardView>

                    <TextView
                        android:id="@+id/tvTotalConsoles"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="16dp"
                        android:textStyle="bold"
                        android:text="Total consolas: 0"
                        android:textColor="@color/azul_noche"
                        android:textSize="17sp" />
                </LinearLayout>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_marginVertical="18dp"
                    android:background="@color/gris_fondo" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="44dp"
                        android:layout_height="44dp"
                        app:cardCornerRadius="12dp"
                        app:cardBackgroundColor="@color/gris_suave"
                        app:cardElevation="0dp">
                        <ImageView
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:layout_gravity="center"
                            android:src="@android:drawable/btn_star_big_on"
                            app:tint="@color/azul_noche" />
                    </com.google.android.material.card.MaterialCardView>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="16dp"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:id="@+id/tvFavCount"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textStyle="bold"
                            android:text="Favoritos: 0"
                            android:textColor="@color/azul_noche"
                            android:textSize="17sp" />

                        <TextView
                            android:id="@+id/tvAvgPrice"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Precio medio: 0.00 €"
                            android:textColor="@color/gris_texto_secundario"
                            android:textSize="14sp"
                            android:alpha="0.8" />
                    </LinearLayout>
                </LinearLayout>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_marginVertical="18dp"
                    android:background="@color/gris_fondo" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <ImageView
                        android:layout_width="22dp"
                        android:layout_height="22dp"
                        android:src="@android:drawable/ic_menu_my_calendar"
                        app:tint="@color/gris_texto_secundario"
                        android:alpha="0.5" />

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="16dp"
                        android:layout_weight="1"
                        android:text="Estado de cuenta"
                        android:textColor="@color/gris_texto_secundario"
                        android:textSize="15sp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textStyle="bold"
                        android:text="Activa"
                        android:textColor="#388E3C"
                        android:textSize="14sp" />
                </LinearLayout>

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnEditProfile"
            android:layout_width="match_parent"
            android:layout_height="70dp"
            android:layout_marginTop="40dp"
            android:text="EDITAR PERFIL"
            android:textStyle="bold"
            android:letterSpacing="0.08"
            android:textColor="@color/white"
            app:backgroundTint="@color/azul_noche"
            app:cornerRadius="24dp"
            app:elevation="8dp"
            app:icon="@android:drawable/ic_menu_edit"
            app:iconGravity="textStart"
            app:iconPadding="12dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnLogout"
            style="@style/Widget.MaterialComponents.Button.TextButton"
            android:layout_width="match_parent"
            android:layout_height="64dp"
            android:layout_marginTop="12dp"
            android:text="CERRAR SESIÓN"
            android:textStyle="bold"
            android:textColor="#D32F2F"
            app:rippleColor="#20D32F2F" />

        <View
            android:layout_width="match_parent"
            android:layout_height="60dp" />

    </LinearLayout>
</androidx.core.widget.NestedScrollView>