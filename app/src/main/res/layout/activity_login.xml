<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/gris_fondo"
    android:fillViewport="true"
    tools:context=".ui.views.LoginActivity">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_horizontal"
        android:orientation="vertical"
        android:padding="32dp">

        <com.google.android.material.card.MaterialCardView
            android:layout_width="120dp"
            android:layout_height="120dp"
            android:layout_marginTop="56dp"
            app:cardCornerRadius="36dp"
            app:cardElevation="14dp"
            app:strokeWidth="0dp">

            <ImageView
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:padding="26dp"
                android:scaleType="centerInside"
                android:src="@drawable/images"
                android:background="@color/white" />
        </com.google.android.material.card.MaterialCardView>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="36dp"
            android:text="Bienvenido"
            android:textStyle="bold"
            android:textColor="@color/azul_noche"
            android:textSize="36sp"
            android:letterSpacing="-0.04" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Inicia sesión para continuar"
            android:textColor="@color/gris_texto_secundario"
            android:textSize="16sp"
            android:alpha="0.7"
            android:layout_marginBottom="48dp" />

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="28dp"
            app:cardElevation="6dp"
            app:strokeColor="#151A1C2E"
            app:strokeWidth="1dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingVertical="6dp">

                <EditText
                    android:id="@+id/etUser"
                    android:layout_width="match_parent"
                    android:layout_height="68dp"
                    android:background="@android:color/transparent"
                    android:drawableStart="@android:drawable/ic_menu_edit"
                    android:drawablePadding="18dp"
                    android:drawableTint="@color/azul_noche"
                    android:hint="Nombre de usuario"
                    android:paddingHorizontal="24dp"
                    android:textColor="@color/azul_noche"
                    android:textSize="16sp"
                    android:inputType="textPersonName" />

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1.5dp"
                    android:layout_marginHorizontal="24dp"
                    android:background="@color/gris_fondo" />

                <EditText
                    android:id="@+id/etEmail"
                    android:layout_width="match_parent"
                    android:layout_height="68dp"
                    android:background="@android:color/transparent"
                    android:drawableStart="@android:drawable/ic_dialog_email"
                    android:drawablePadding="18dp"
                    android:drawableTint="@color/azul_noche"
                    android:hint="Correo electrónico"
                    android:inputType="textEmailAddress"
                    android:paddingHorizontal="24dp"
                    android:textColor="@color/azul_noche"
                    android:textSize="16sp" />

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1.5dp"
                    android:layout_marginHorizontal="24dp"
                    android:background="@color/gris_fondo" />

                <EditText
                    android:id="@+id/etPassword"
                    android:layout_width="match_parent"
                    android:layout_height="68dp"
                    android:background="@android:color/transparent"
                    android:drawableStart="@android:drawable/ic_lock_idle_lock"
                    android:drawablePadding="18dp"
                    android:drawableTint="@color/azul_noche"
                    android:hint="Contraseña"
                    android:inputType="textPassword"
                    android:paddingHorizontal="24dp"
                    android:textColor="@color/azul_noche"
                    android:textSize="16sp" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnLogin"
            android:layout_width="match_parent"
            android:layout_height="72dp"
            android:layout_marginTop="44dp"
            android:text="INGRESAR"
            android:textSize="17sp"
            android:textStyle="bold"
            android:textColor="@color/white"
            app:backgroundTint="@color/azul_noche"
            app:cornerRadius="24dp"
            app:elevation="10dp"
            android:letterSpacing="0.1" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="36dp"
            android:gravity="center"
            android:orientation="vertical">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnRegister"
                style="@style/Widget.MaterialComponents.Button.TextButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="¿No tienes cuenta? Regístrate"
                android:textColor="@color/azul_noche"
                android:textAllCaps="false"
                android:textStyle="bold"
                android:textSize="15sp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnRecover"
                style="@style/Widget.MaterialComponents.Button.TextButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Olvidé mi contraseña"
                android:textColor="@color/gris_texto_secundario"
                android:textAllCaps="false"
                android:textSize="14sp"
                android:alpha="0.6" />
        </LinearLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="60dp" />

    </LinearLayout>
</androidx.core.widget.NestedScrollView>