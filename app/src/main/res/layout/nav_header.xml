<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="220dp"
    android:background="@color/azul_noche"
    android:padding="24dp">

    <View
        android:layout_width="150dp"
        android:layout_height="150dp"
        android:background="@drawable/shape_circle_white_alpha"
        android:alpha="0.05"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        android:layout_marginTop="-50dp"
        android:layout_marginEnd="-50dp" />

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/cvUserContainer"
        android:layout_width="84dp"
        android:layout_height="84dp"
        app:cardCornerRadius="42dp"
        app:cardElevation="12dp"
        app:strokeColor="#60FFFFFF"
        app:strokeWidth="3dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        android:layout_marginTop="8dp">

        <ImageView
            android:id="@+id/imgUser"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:scaleType="centerCrop"
            android:background="@color/gris_suave"
            tools:src="@android:drawable/ic_menu_gallery" />
    </com.google.android.material.card.MaterialCardView>

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:orientation="vertical"
        app:layout_constraintTop_toBottomOf="@id/cvUserContainer"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView
            android:id="@+id/tvUserName"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textStyle="bold"
            android:textColor="@color/white"
            android:textSize="22sp"
            android:letterSpacing="-0.02"
            android:ellipsize="end"
            android:maxLines="1"
            tools:text="Joaquín Domingo" />

        <TextView
            android:id="@+id/tvUserEmail"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:textColor="@color/white"
            android:alpha="0.6"
            android:textSize="14sp"
            android:ellipsize="end"
            android:maxLines="1"
            tools:text="joaquin.dev@ejemplo.com" />

    </LinearLayout>

    <View
        android:layout_width="32dp"
        android:layout_height="3dp"
        android:background="@color/white"
        android:alpha="0.3"
        app:cardCornerRadius="2dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        android:layout_marginBottom="8dp" />

</androidx.constraintlayout.widget.ConstraintLayout>