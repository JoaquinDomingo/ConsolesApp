<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="220dp"
    android:background="@color/azul_noche"
    android:padding="28dp">

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/cvUserContainer"
        android:layout_width="90dp"
        android:layout_height="90dp"
        app:cardCornerRadius="45dp"
        app:cardElevation="8dp"
        app:strokeColor="#40FFFFFF"
        app:strokeWidth="3dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <ImageView
            android:id="@+id/imgUser"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:scaleType="centerCrop"
            android:src="@drawable/images"
            android:background="@color/gris_suave"
            tools:src="@android:drawable/ic_menu_gallery" />
    </com.google.android.material.card.MaterialCardView>

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        android:orientation="vertical"
        app:layout_constraintTop_toBottomOf="@id/cvUserContainer"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView
            android:id="@+id/tvUserName"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textStyle="bold"
            android:text="Nombre Usuario"
            android:textColor="@color/white"
            android:textSize="24sp"
            android:letterSpacing="-0.03"
            android:ellipsize="end"
            android:maxLines="1" />

        <TextView
            android:id="@+id/tvUserEmail"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="correo@ejemplo.com"
            android:textColor="@color/white"
            android:alpha="0.7"
            android:textSize="15sp"
            android:layout_marginTop="4dp"
            android:ellipsize="end"
            android:maxLines="1" />

    </LinearLayout>

    <View
        android:layout_width="40dp"
        android:layout_height="4dp"
        android:background="@color/white"
        android:alpha="0.2"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>