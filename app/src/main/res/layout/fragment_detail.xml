<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/gris_fondo"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="28dp">

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="320dp"
            android:layout_marginBottom="32dp"
            app:cardCornerRadius="32dp"
            app:cardElevation="12dp"
            app:strokeWidth="0dp">

            <ImageView
                android:id="@+id/tvDetailImage"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@color/gris_suave"
                android:scaleType="centerCrop"
                tools:src="@android:drawable/ic_menu_gallery" />
        </com.google.android.material.card.MaterialCardView>

        <TextView
            android:id="@+id/tvDetailName"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textStyle="bold"
            android:letterSpacing="-0.04"
            android:textColor="@color/azul_noche"
            android:textSize="38sp"
            tools:text="Nintendo Switch" />

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            app:cardBackgroundColor="@color/white"
            app:cardCornerRadius="24dp"
            app:cardElevation="4dp"
            app:strokeColor="#101A1C2E"
            app:strokeWidth="1dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@android:drawable/ic_menu_agenda"
                        app:tint="@color/azul_noche" />

                    <TextView
                        android:id="@+id/tvDetailCompany"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="16dp"
                        android:textStyle="bold"
                        android:textColor="@color/azul_noche"
                        android:textSize="19sp"
                        tools:text="Nintendo" />
                </LinearLayout>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_marginVertical="16dp"
                    android:background="@color/gris_fondo" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@android:drawable/ic_menu_my_calendar"
                        app:tint="@color/gris_texto_secundario" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="16dp"
                        android:orientation="vertical">

                        <TextView
                            android:id="@+id/tvDetailDate"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textColor="@color/gris_texto_secundario"
                            android:textSize="15sp"
                            android:alpha="0.8"
                            tools:text="Lanzado en 2017" />

                        <TextView
                            android:id="@+id/tvDetailPrice"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:textStyle="bold"
                            android:textColor="@color/azul_noche"
                            android:textSize="18sp"
                            tools:text="Precio: 299.99 €" />
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="40dp"
            android:letterSpacing="0.15"
            android:text="HISTORIA Y DETALLES"
            android:textColor="@color/azul_noche"
            android:textSize="13sp"
            android:textStyle="bold"
            android:alpha="0.6" />

        <TextView
            android:id="@+id/tvDetailDescription"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:lineSpacingExtra="8dp"
            android:textColor="@color/gris_texto_secundario"
            android:textSize="18sp"
            tools:text="Consola híbrida de gran éxito..." />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="48dp"
            android:letterSpacing="0.15"
            android:text="EXPLORAR CONTENIDO"
            android:textColor="@color/azul_noche"
            android:textSize="13sp"
            android:textStyle="bold"
            android:alpha="0.6" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnFavorite"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:layout_marginTop="16dp"
            android:text="Añadir a mis favoritos"
            android:textStyle="bold"
            android:textColor="@color/azul_noche"
            app:cornerRadius="20dp"
            app:strokeColor="@color/azul_noche"
            app:strokeWidth="1dp"
            app:icon="@android:drawable/btn_star_big_off"
            app:iconTint="@color/azul_noche"
            app:iconGravity="textStart" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnGoToNative"
            android:layout_width="match_parent"
            android:layout_height="72dp"
            android:layout_marginTop="16dp"
            android:backgroundTint="@color/azul_noche"
            android:text="VER JUEGOS NATIVOS"
            android:textSize="16sp"
            android:textStyle="bold"
            app:cornerRadius="24dp"
            app:elevation="8dp"
            app:icon="@android:drawable/ic_menu_view"
            app:iconSize="24dp"
            app:iconPadding="12dp"
            app:iconGravity="textStart" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnGoToAdapted"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="match_parent"
            android:layout_height="72dp"
            android:layout_marginTop="16dp"
            android:text="BIBLIOTECA ADAPTADA"
            android:textColor="@color/azul_noche"
            android:textSize="16sp"
            android:textStyle="bold"
            app:cornerRadius="24dp"
            app:strokeColor="@color/azul_noche"
            app:strokeWidth="2dp"
            app:icon="@android:drawable/ic_menu_share"
            app:iconPadding="12dp"
            app:iconTint="@color/azul_noche"
            app:iconGravity="textStart" />

        <View
            android:layout_width="match_parent"
            android:layout_height="60dp" />

    </LinearLayout>
</androidx.core.widget.NestedScrollView>