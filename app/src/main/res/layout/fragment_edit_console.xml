<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/gris_fondo">

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="40dp">

            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="220dp"
                android:background="@color/azul_noche">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_centerHorizontal="true"
                    android:layout_marginTop="40dp"
                    android:text="EDICIÓN TÉCNICA"
                    android:textColor="@color/white"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.2"
                    android:alpha="0.9" />

                <RelativeLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentBottom="true"
                    android:layout_centerHorizontal="true"
                    android:layout_marginBottom="-55dp">

                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/cvEditImageContainer"
                        android:layout_width="140dp"
                        android:layout_height="140dp"
                        app:cardCornerRadius="36dp"
                        app:cardElevation="16dp"
                        app:strokeWidth="4dp"
                        app:strokeColor="@color/white">

                        <ImageView
                            android:id="@+id/ivEditConsolePreview"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:scaleType="centerCrop"
                            android:background="#FAFAFA"
                            tools:src="@android:drawable/ic_menu_gallery" />
                    </com.google.android.material.card.MaterialCardView>

                    <com.google.android.material.floatingactionbutton.FloatingActionButton
                        android:id="@+id/btnEditSelectImage"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignBottom="@id/cvEditImageContainer"
                        android:layout_alignEnd="@id/cvEditImageContainer"
                        android:layout_marginEnd="-12dp"
                        android:layout_marginBottom="-12dp"
                        app:fabCustomSize="48dp"
                        app:maxImageSize="24dp"
                        app:srcCompat="@android:drawable/ic_menu_camera"
                        app:backgroundTint="@color/white"
                        app:tint="@color/azul_noche"
                        app:elevation="20dp" />
                </RelativeLayout>
            </RelativeLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="75dp"
                android:orientation="vertical"
                android:paddingHorizontal="24dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="DATOS PRINCIPALES"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:textColor="@color/gris_texto_secundario"
                    android:layout_marginBottom="12dp"
                    android:letterSpacing="0.1" />

                <com.google.android.material.textfield.TextInputLayout
                    style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:startIconDrawable="@android:drawable/ic_menu_edit"
                    app:startIconTint="@color/azul_noche"
                    android:hint="Nombre del sistema">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etEditName"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="textCapWords"
                        android:textSize="16sp" />
                </com.google.android.material.textfield.TextInputLayout>

                <com.google.android.material.textfield.TextInputLayout
                    style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    app:startIconDrawable="@android:drawable/ic_menu_agenda"
                    app:startIconTint="@color/azul_noche"
                    android:hint="Compañía / Fabricante">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etEditCompany"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="textCapWords" />
                </com.google.android.material.textfield.TextInputLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:orientation="horizontal">

                    <com.google.android.material.textfield.TextInputLayout
                        style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginEnd="6dp"
                        app:startIconDrawable="@android:drawable/ic_menu_my_calendar"
                        android:hint="Año">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/etEditDate"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:inputType="number" />
                    </com.google.android.material.textfield.TextInputLayout>

                    <com.google.android.material.textfield.TextInputLayout
                        style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="6dp"
                        app:startIconDrawable="@android:drawable/ic_menu_save"
                        android:hint="Precio (€)">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/etPrice"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:inputType="numberDecimal" />
                    </com.google.android.material.textfield.TextInputLayout>
                </LinearLayout>

                <com.google.android.material.textfield.TextInputLayout
                    style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    app:startIconDrawable="@android:drawable/ic_menu_gallery"
                    android:hint="URL de imagen externa (opcional)">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etEditImage"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="textUri" />
                </com.google.android.material.textfield.TextInputLayout>

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="20dp"
                    app:cardCornerRadius="20dp"
                    app:cardElevation="0dp"
                    app:strokeWidth="1dp"
                    app:strokeColor="#DADCE0">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="16dp">

                        <com.google.android.material.switchmaterial.SwitchMaterial
                            android:id="@+id/swFavorite"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="Consola Favorita"
                            android:textStyle="bold"
                            android:textColor="@color/azul_noche" />

                        <com.google.android.material.textfield.TextInputLayout
                            style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="12dp"
                            android:hint="Descripción y detalles">

                            <com.google.android.material.textfield.TextInputEditText
                                android:id="@+id/etEditDescription"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:minLines="4"
                                android:gravity="top"
                                android:inputType="textMultiLine" />
                        </com.google.android.material.textfield.TextInputLayout>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnUpdateConsole"
                    android:layout_width="match_parent"
                    android:layout_height="64dp"
                    android:layout_marginTop="32dp"
                    android:text="SINCRONIZAR CAMBIOS"
                    android:textStyle="bold"
                    android:letterSpacing="0.1"
                    app:cornerRadius="16dp"
                    android:backgroundTint="@color/azul_noche"
                    app:icon="@android:drawable/ic_menu_save"
                    app:iconGravity="textStart"
                    app:iconPadding="12dp"
                    app:elevation="8dp" />

            </LinearLayout>
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>
</androidx.coordinatorlayout.widget.CoordinatorLayout>