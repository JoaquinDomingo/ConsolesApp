<resources xmlns:tools="http://schemas.android.com/tools">
    <style name="Base.Theme.Consolas" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="fontFamily">@font/sans_serif_black</item>
        <item name="android:fontFamily">@font/sans_serif_black</item>

        <item name="colorPrimary">@color/azul_noche</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="android:windowBackground">@color/gris_fondo</item>

        <item name="textAppearanceHeadlineLarge">@style/TextAppearance.MyApp.Headline.Large</item>
        <item name="textAppearanceHeadlineMedium">@style/TextAppearance.MyApp.Headline.Medium</item>

        <item name="shapeAppearanceLargeComponent">@style/ShapeAppearance.MyApp.Large</item>
    </style>

    <style name="Theme.Consolas" parent="Base.Theme.Consolas" />

    <style name="TextAppearance.MyApp.Headline.Large" parent="TextAppearance.Material3.HeadlineLarge">
        <item name="android:fontFamily">@font/sans_serif_black</item>
        <item name="fontFamily">@font/sans_serif_black</item>
        <item name="android:textColor">@color/azul_noche</item>
        <item name="android:letterSpacing">-0.04</item>
        <item name="android:textStyle">normal</item>
    </style>

    <style name="TextAppearance.MyApp.Headline.Medium" parent="TextAppearance.Material3.HeadlineMedium">
        <item name="android:fontFamily">@font/sans_serif_black</item>
        <item name="fontFamily">@font/sans_serif_black</item>
        <item name="android:textColor">@color/azul_noche</item>
        <item name="android:letterSpacing">-0.02</item>
    </style>

    <style name="ShapeAppearance.MyApp.Large" parent="ShapeAppearance.Material3.MediumComponent">
        <item name="cornerSize">28dp</item>
    </style>
</resources>